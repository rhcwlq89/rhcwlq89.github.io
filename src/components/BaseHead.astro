---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE, AUTHOR_NAME, LOCALE_MAP } from '../consts';
import type { Lang } from '../i18n/languages';
import { getAlternateLangPath } from '../i18n/utils';

interface Props {
	title: string;
	description: string;
	lang?: Lang;
	image?: ImageMetadata;
	type?: 'website' | 'article';
	publishedTime?: Date;
	modifiedTime?: Date;
	noindex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	lang = 'ko',
	image,
	type = 'website',
	publishedTime,
	modifiedTime,
	noindex = false
} = Astro.props;

const imageURL = image ? new URL(image.src, Astro.url) : null;
const ogLocale = LOCALE_MAP[lang] || 'ko_KR';
const alternate = getAlternateLangPath(Astro.url);
const alternateURL = new URL(alternate.path, Astro.site);

// JSON-LD 구조화된 데이터
const jsonLd = type === 'article' ? {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": title,
	"description": description,
	...(imageURL && { "image": imageURL.href }),
	"author": {
		"@type": "Person",
		"name": AUTHOR_NAME
	},
	"publisher": {
		"@type": "Organization",
		"name": SITE_TITLE,
		"logo": {
			"@type": "ImageObject",
			"url": new URL('/favicon.svg', Astro.site).href
		}
	},
	"url": canonicalURL.href,
	"datePublished": publishedTime?.toISOString(),
	"dateModified": (modifiedTime || publishedTime)?.toISOString(),
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": canonicalURL.href
	}
} : {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": SITE_TITLE,
	"description": description,
	"url": Astro.site?.href
};

// Breadcrumb (article pages only): Home > Blog > Current
const breadcrumbLd = type === 'article' ? {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": lang === 'en' ? "Home" : "홈",
			"item": new URL(lang === 'en' ? '/en/' : '/', Astro.site).href
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": lang === 'en' ? "Blog" : "블로그",
			"item": new URL(lang === 'en' ? '/en/blog/' : '/blog/', Astro.site).href
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": title,
			"item": canonicalURL.href
		}
	]
} : null;
---

<!-- 다크모드 FOUC 방지 (페이지 로드 전 테마 적용) -->
<script is:inline>
  (function() {
    const stored = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    if (stored === 'dark' || (!stored && prefersDark)) {
      document.documentElement.classList.add('dark');
    }
  })();
</script>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="google-site-verification" content="rIGaSlO4bB38ITRwii9ywCk6RfNh7W1EsI1DTVXhN-I" />
<meta name="naver-site-verification" content="c639aec36ad33273427cf9a0bb297c60208dcb47" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL(lang === 'en' ? 'en/rss.xml' : 'rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- hreflang -->
<link rel="alternate" hreflang={lang} href={canonicalURL} />
<link rel="alternate" hreflang={alternate.lang} href={alternateURL} />
<link rel="alternate" hreflang="x-default" href={new URL(lang === 'ko' ? Astro.url.pathname : alternate.path, Astro.site)} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={AUTHOR_NAME} />
{noindex && <meta name="robots" content="noindex,follow" />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{imageURL && <meta property="og:image" content={imageURL} />}
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={ogLocale} />
{type === 'article' && publishedTime && (
	<meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{type === 'article' && modifiedTime && (
	<meta property="article:modified_time" content={modifiedTime.toISOString()} />
)}
{type === 'article' && (
	<meta property="article:author" content={AUTHOR_NAME} />
)}

<!-- Twitter -->
<meta name="twitter:card" content={imageURL ? "summary_large_image" : "summary"} />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{imageURL && <meta name="twitter:image" content={imageURL} />}

<!-- JSON-LD 구조화된 데이터 -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
{breadcrumbLd && (
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
)}

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-N2ZJ87F6YX"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-N2ZJ87F6YX');
</script>
