---
import { AFFILIATE } from '../consts';

interface Props {
  lang?: string;
}

const { lang = 'ko' } = Astro.props;
const amazonTag = AFFILIATE.amazon.tag;
---

<div class="affiliate-banner" id="affiliate-banner">
  <div class="affiliate-card" id="ad-card">
    <button class="affiliate-close" aria-label={lang === 'ko' ? '닫기' : 'Close'} id="affiliate-close-btn">&times;</button>
    <div class="affiliate-body">
      {lang === 'ko' ? (
        <div class="affiliate-coupang-widget">
          <script is:inline src="https://ads-partners.coupang.com/g.js"></script>
          <script is:inline define:vars={{ coupangId: AFFILIATE.coupang.id, coupangTracking: AFFILIATE.coupang.trackingCode }}>
            new PartnersCoupang.G({"id":coupangId,"template":"carousel","trackingCode":coupangTracking,"width":"100%","height":"140","tsource":""});
          </script>
        </div>
      ) : (
        <a class="affiliate-amazon-link" href={`https://www.amazon.com/b?_encoding=UTF8&node=121739139011&discounts-widget=%2522%257B%255C%2522state%255C%2522%253A%257B%255C%2522refinementFilters%255C%2522%253A%257B%255C%2522departments%255C%2522%253A%255B%255C%252211846801%255C%2522%255D%257D%257D%252C%255C%2522version%255C%2522%253A1%257D%2522&pd_rd_w=uE9Bp&content-id=amzn1.sym.9bcff824-c298-412d-8183-e90f90252475&pf_rd_p=9bcff824-c298-412d-8183-e90f90252475&pf_rd_r=A6HXFZ2JRN13VV0FM2D2&pd_rd_wg=bBawn&pd_rd_r=40edd336-8466-4101-bcab-daa096e91d8f&linkCode=ll2&tag=${amazonTag}&linkId=9560b47e65ec3d5d005218ad29cb9f90&language=en_US&ref_=as_li_ss_tl`} target="_blank" rel="noopener noreferrer sponsored">
          <div class="affiliate-amazon-banner">
            <svg class="amazon-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 603 182" width="100" height="30">
              <path fill="currentColor" d="M374.00 142.06C339.63 167.17 289.65 180.50 247.04 180.50C187.95 180.50 135.18 158.98 95.41 123.66C92.26 120.81 95.07 116.94 98.87 119.19C141.65 144.16 194.60 159.12 249.35 159.12C286.41 159.12 327.02 151.50 364.42 135.71C369.88 133.40 374.49 138.58 374.00 142.06Z"/>
              <path fill="currentColor" d="M385.76 128.44C381.52 122.98 356.87 125.94 345.74 127.27C342.42 127.67 341.92 124.76 344.92 122.66C364.76 108.60 397.34 112.60 401.00 117.14C404.66 121.72 399.98 154.30 381.34 170.00C378.54 172.38 375.88 171.12 377.14 167.98C381.28 157.78 389.98 133.86 385.76 128.44Z"/>
              <path fill="#currentColor" d="M346.34 20.86L346.34 6.42C346.34 4.32 347.92 2.94 349.82 2.94L411.76 2.94C413.74 2.94 415.32 4.36 415.32 6.42L415.32 19.20C415.28 21.18 413.58 23.78 410.70 27.80L378.56 74.26C390.62 73.96 403.36 75.76 414.24 81.92C416.72 83.32 417.38 85.36 417.56 87.34L417.56 102.74C417.56 104.76 415.34 107.10 413.02 105.88C392.78 95.22 365.80 94.06 343.54 106.02C341.42 107.16 339.16 104.86 339.16 102.84L339.16 88.18C339.16 85.94 339.20 82.06 341.46 78.68L379.08 24.22L349.90 24.22C347.92 24.22 346.34 22.84 346.34 20.86Z"/>
            </svg>
            <span class="amazon-cta">Shop on Amazon</span>
          </div>
        </a>
      )}
      <p class="affiliate-disclosure">
        {lang === 'ko'
          ? '이 포스팅은 쿠팡 파트너스 활동의 일환으로, 이에 따른 일정액의 수수료를 제공받습니다.'
          : 'As an Amazon Associate, I earn from qualifying purchases.'}
      </p>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var card = document.getElementById('ad-card');
  var btn = document.getElementById('affiliate-close-btn');
  if (!card || !btn) return;

  if (sessionStorage.getItem('affiliate-dismissed')) {
    card.style.display = 'none';
    return;
  }

  btn.addEventListener('click', function() {
    card.style.display = 'none';
    sessionStorage.setItem('affiliate-dismissed', '1');
  });
})();
</script>

<style>
  .affiliate-banner {
    margin: 2em 0 1em;
  }

  .affiliate-card {
    position: relative;
    border-radius: 10px;
    padding: 1.2em 1.5em;
    background-color: rgba(var(--gray-light), 0.4);
    border: 1px solid rgb(var(--gray-light));
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .affiliate-body {
    text-align: center;
  }

  .affiliate-disclosure {
    font-size: 0.78em;
    color: rgb(var(--gray));
    margin: 0.8em 0 0;
    text-align: center;
  }

  .affiliate-close {
    position: absolute;
    top: 0.5em;
    right: 0.7em;
    background: none;
    border: none;
    font-size: 1.3em;
    cursor: pointer;
    color: rgb(var(--gray));
    line-height: 1;
    padding: 0.2em;
    z-index: 1;
    transition: color 0.2s ease;
  }

  .affiliate-close:hover {
    color: rgb(var(--gray-dark));
  }

  .affiliate-coupang-widget {
    margin-bottom: 0.5em;
    overflow: hidden;
    border-radius: 6px;
  }

  .affiliate-amazon-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .affiliate-amazon-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1em;
    padding: 1em 1.5em;
    border-radius: 6px;
    background: linear-gradient(135deg, #232f3e 0%, #37475a 100%);
    color: #ff9900;
    transition: opacity 0.2s ease;
  }

  .affiliate-amazon-banner:hover {
    opacity: 0.9;
  }

  .amazon-logo {
    flex-shrink: 0;
  }

  .amazon-cta {
    font-size: 1.1em;
    font-weight: 600;
    color: #ffffff;
  }

  @media (max-width: 900px) {
    .affiliate-card {
      padding: 1em;
    }
  }
</style>
