---
import { AFFILIATE } from '../consts';

interface Props {
  lang?: string;
}

const { lang = 'ko' } = Astro.props;
const isKorean = lang === 'ko';
---

<div class="affiliate-banner" id="affiliate-banner">
  {isKorean ? (
    <!-- Korean: Coupang Partners -->
    <div class="affiliate-card affiliate-coupang" id="ad-card">
      <button class="affiliate-close" aria-label="닫기" id="affiliate-close-btn">&times;</button>
      <div class="affiliate-body">
        <div class="affiliate-coupang-widget">
          <script is:inline src="https://ads-partners.coupang.com/g.js"></script>
          <script is:inline define:vars={{ coupangId: AFFILIATE.coupang.id, coupangTracking: AFFILIATE.coupang.trackingCode }}>
            new PartnersCoupang.G({"id":coupangId,"template":"carousel","trackingCode":coupangTracking,"width":"100%","height":"140","tsource":""});
          </script>
        </div>
        <p class="affiliate-disclosure">
          이 포스팅은 쿠팡 파트너스 활동의 일환으로, 이에 따른 일정액의 수수료를 제공받습니다.
        </p>
      </div>
    </div>
  ) : (
    <!-- English: Amazon Associates -->
    <div class="affiliate-card affiliate-amazon" id="ad-card">
      <button class="affiliate-close" aria-label="Close" id="affiliate-close-btn">&times;</button>
      <a class="amazon-card-link" href={AFFILIATE.amazon.link} target="_blank" rel="noopener noreferrer nofollow">
        <div class="amazon-card-inner">
          <div class="amazon-card-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <path d="M16 10a4 4 0 0 1-8 0"></path>
            </svg>
          </div>
          <div class="amazon-card-text">
            <strong class="amazon-card-title">Recommended Developer Tools & Books</strong>
            <span class="amazon-card-desc">Curated picks for developers — keyboards, monitors, books & more.</span>
          </div>
          <div class="amazon-card-cta">
            <span class="amazon-card-btn">Shop on Amazon &rarr;</span>
          </div>
        </div>
      </a>
      <p class="affiliate-disclosure">
        As an Amazon Associate I earn from qualifying purchases.
      </p>
    </div>
  )}
</div>

<script is:inline>
(function() {
  var card = document.getElementById('ad-card');
  var btn = document.getElementById('affiliate-close-btn');
  if (!card || !btn) return;

  // Check sessionStorage for dismissed state
  if (sessionStorage.getItem('affiliate-dismissed')) {
    card.style.display = 'none';
    return;
  }

  btn.addEventListener('click', function() {
    card.style.display = 'none';
    sessionStorage.setItem('affiliate-dismissed', '1');
  });
})();
</script>

<style>
  .affiliate-banner {
    margin: 2em 0 1em;
  }

  .affiliate-card {
    position: relative;
    border-radius: 10px;
    padding: 1.2em 1.5em;
    background-color: rgba(var(--gray-light), 0.4);
    border: 1px solid rgb(var(--gray-light));
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .affiliate-body {
    text-align: center;
  }

  .affiliate-disclosure {
    font-size: 0.78em;
    color: rgb(var(--gray));
    margin: 0.8em 0 0;
    text-align: center;
  }

  .affiliate-close {
    position: absolute;
    top: 0.5em;
    right: 0.7em;
    background: none;
    border: none;
    font-size: 1.3em;
    cursor: pointer;
    color: rgb(var(--gray));
    line-height: 1;
    padding: 0.2em;
    z-index: 1;
    transition: color 0.2s ease;
  }

  .affiliate-close:hover {
    color: rgb(var(--gray-dark));
  }

  .affiliate-coupang-widget {
    margin-bottom: 0.5em;
    overflow: hidden;
    border-radius: 6px;
  }

  /* Amazon card design */
  .amazon-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .amazon-card-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(var(--gray), 0.3);
    color: inherit;
  }

  .amazon-card-inner {
    display: flex;
    align-items: center;
    gap: 1em;
    padding: 1em 1.2em;
    background: linear-gradient(135deg, rgba(var(--gray-light), 0.5), rgba(var(--gray-light), 0.2));
    border: 1px solid rgba(var(--gray-light), 0.8);
    border-radius: 8px;
  }

  .amazon-card-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 10px;
    background-color: var(--accent);
    color: #fff;
  }

  .amazon-card-text {
    flex: 1;
    min-width: 0;
    text-align: left;
  }

  .amazon-card-title {
    display: block;
    font-size: 0.95em;
    font-weight: 700;
    color: rgb(var(--black));
    margin-bottom: 0.2em;
  }

  .amazon-card-desc {
    display: block;
    font-size: 0.82em;
    color: rgb(var(--gray));
    line-height: 1.4;
  }

  .amazon-card-cta {
    flex-shrink: 0;
  }

  .amazon-card-btn {
    display: inline-block;
    padding: 0.5em 1em;
    border-radius: 6px;
    background-color: var(--accent);
    color: #fff;
    font-size: 0.82em;
    font-weight: 600;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .amazon-card-link:hover .amazon-card-btn {
    opacity: 0.85;
  }

  @media (max-width: 900px) {
    .affiliate-card {
      padding: 1em;
    }

    .amazon-card-inner {
      flex-direction: column;
      text-align: center;
      gap: 0.8em;
    }

    .amazon-card-text {
      text-align: center;
    }

    .amazon-card-icon {
      width: 44px;
      height: 44px;
    }

    .amazon-card-icon svg {
      width: 28px;
      height: 28px;
    }
  }
</style>
