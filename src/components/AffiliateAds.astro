---
import { AFFILIATE } from '../consts';

interface Props {
  lang?: string;
}

const { lang = 'ko' } = Astro.props;
---

<div class="affiliate-banner" id="affiliate-banner">
  <div class="affiliate-card" id="ad-card">
    <button class="affiliate-close" aria-label={lang === 'ko' ? '닫기' : 'Close'} id="affiliate-close-btn">&times;</button>
    <div class="affiliate-body">
      <div class="affiliate-coupang-widget">
        <script is:inline src="https://ads-partners.coupang.com/g.js"></script>
        <script is:inline define:vars={{ coupangId: AFFILIATE.coupang.id, coupangTracking: AFFILIATE.coupang.trackingCode }}>
          new PartnersCoupang.G({"id":coupangId,"template":"carousel","trackingCode":coupangTracking,"width":"100%","height":"140","tsource":""});
        </script>
      </div>
      <p class="affiliate-disclosure">
        {lang === 'ko'
          ? '이 포스팅은 쿠팡 파트너스 활동의 일환으로, 이에 따른 일정액의 수수료를 제공받습니다.'
          : 'This post is part of the Coupang Partners program, and a commission is earned from qualifying purchases.'}
      </p>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var card = document.getElementById('ad-card');
  var btn = document.getElementById('affiliate-close-btn');
  if (!card || !btn) return;

  if (sessionStorage.getItem('affiliate-dismissed')) {
    card.style.display = 'none';
    return;
  }

  btn.addEventListener('click', function() {
    card.style.display = 'none';
    sessionStorage.setItem('affiliate-dismissed', '1');
  });
})();
</script>

<style>
  .affiliate-banner {
    margin: 2em 0 1em;
  }

  .affiliate-card {
    position: relative;
    border-radius: 10px;
    padding: 1.2em 1.5em;
    background-color: rgba(var(--gray-light), 0.4);
    border: 1px solid rgb(var(--gray-light));
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .affiliate-body {
    text-align: center;
  }

  .affiliate-disclosure {
    font-size: 0.78em;
    color: rgb(var(--gray));
    margin: 0.8em 0 0;
    text-align: center;
  }

  .affiliate-close {
    position: absolute;
    top: 0.5em;
    right: 0.7em;
    background: none;
    border: none;
    font-size: 1.3em;
    cursor: pointer;
    color: rgb(var(--gray));
    line-height: 1;
    padding: 0.2em;
    z-index: 1;
    transition: color 0.2s ease;
  }

  .affiliate-close:hover {
    color: rgb(var(--gray-dark));
  }

  .affiliate-coupang-widget {
    margin-bottom: 0.5em;
    overflow: hidden;
    border-radius: 6px;
  }

  @media (max-width: 900px) {
    .affiliate-card {
      padding: 1em;
    }
  }
</style>
