---
import { AFFILIATE } from '../consts';

interface Props {
  lang?: string;
}

const { lang = 'ko' } = Astro.props;
---

<div
  class="affiliate-banner"
  id="affiliate-banner"
  data-page-lang={lang}
  data-coupang-id={AFFILIATE.coupang.id}
  data-coupang-tracking={AFFILIATE.coupang.trackingCode}
  data-coupang-link={AFFILIATE.coupang.link}
  data-amazon-link={AFFILIATE.amazon.link}
>
  <!-- Korean: Coupang Partners -->
  <div class="affiliate-card affiliate-coupang" id="ad-coupang" style="display:none;">
    <button class="affiliate-close" aria-label="닫기" data-target="ad-coupang">&times;</button>
    <div class="affiliate-body">
      <div class="affiliate-coupang-widget" id="coupang-widget"></div>
      <p class="affiliate-disclosure">
        이 포스팅은 쿠팡 파트너스 활동의 일환으로, 이에 따른 일정액의 수수료를 제공받습니다.
      </p>
    </div>
  </div>

  <!-- English: Amazon Associates -->
  <div class="affiliate-card affiliate-amazon" id="ad-amazon" style="display:none;">
    <button class="affiliate-close" aria-label="Close" data-target="ad-amazon">&times;</button>
    <a class="amazon-card-link" href={AFFILIATE.amazon.link} target="_blank" rel="noopener noreferrer nofollow">
      <div class="amazon-card-inner">
        <div class="amazon-card-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
        </div>
        <div class="amazon-card-text">
          <strong class="amazon-card-title">Recommended Developer Tools & Books</strong>
          <span class="amazon-card-desc">Curated picks for developers — keyboards, monitors, books & more.</span>
        </div>
        <div class="amazon-card-cta">
          <span class="amazon-card-btn">Shop on Amazon &rarr;</span>
        </div>
      </div>
    </a>
    <p class="affiliate-disclosure">
      As an Amazon Associate I earn from qualifying purchases.
    </p>
  </div>
</div>

<script is:inline>
(function() {
  var banner = document.getElementById('affiliate-banner');
  if (!banner) return;

  var pageLang = banner.dataset.pageLang || 'ko';

  // Show ad based on the page language: Korean page → Coupang, English page → Amazon
  var showCoupang = pageLang === 'ko';

  var coupangEl = document.getElementById('ad-coupang');
  var amazonEl = document.getElementById('ad-amazon');

  // Check sessionStorage for dismissed state
  var dismissedKey = showCoupang ? 'affiliate-coupang-dismissed' : 'affiliate-amazon-dismissed';
  if (sessionStorage.getItem(dismissedKey)) return;

  if (showCoupang && coupangEl) {
    coupangEl.style.display = '';
    // Load Coupang widget
    var widgetContainer = document.getElementById('coupang-widget');
    if (widgetContainer) {
      var script = document.createElement('script');
      script.src = 'https://ads-partners.coupang.com/g.js';
      script.onload = function() {
        if (typeof PartnersCoupang !== 'undefined') {
          new PartnersCoupang.G({
            id: parseInt(banner.dataset.coupangId),
            template: 'carousel',
            trackingCode: banner.dataset.coupangTracking,
            width: '100%',
            height: '140',
            tsource: ''
          });
        }
      };
      widgetContainer.appendChild(script);
    }
  } else if (!showCoupang && amazonEl) {
    amazonEl.style.display = '';
  }

  // Close button handlers
  var closeButtons = banner.querySelectorAll('.affiliate-close');
  closeButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var targetId = btn.dataset.target;
      var target = document.getElementById(targetId);
      if (target) {
        target.style.display = 'none';
        var key = targetId === 'ad-coupang' ? 'affiliate-coupang-dismissed' : 'affiliate-amazon-dismissed';
        sessionStorage.setItem(key, '1');
      }
    });
  });
})();
</script>

<style>
  .affiliate-banner {
    margin: 2em 0 1em;
  }

  .affiliate-card {
    position: relative;
    border-radius: 10px;
    padding: 1.2em 1.5em;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  /* Coupang - uses blog accent tones */
  .affiliate-coupang {
    background-color: rgba(var(--gray-light), 0.4);
    border: 1px solid rgb(var(--gray-light));
  }

  /* Amazon - warm accent */
  .affiliate-amazon {
    background-color: rgba(var(--gray-light), 0.4);
    border: 1px solid rgb(var(--gray-light));
  }

  .affiliate-body {
    text-align: center;
  }

  .affiliate-disclosure {
    font-size: 0.78em;
    color: rgb(var(--gray));
    margin: 0.8em 0 0;
    text-align: center;
  }

  /* Amazon card design */
  .amazon-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .amazon-card-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(var(--gray), 0.3);
    color: inherit;
  }

  .amazon-card-inner {
    display: flex;
    align-items: center;
    gap: 1em;
    padding: 1em 1.2em;
    background: linear-gradient(135deg, rgba(var(--gray-light), 0.5), rgba(var(--gray-light), 0.2));
    border: 1px solid rgba(var(--gray-light), 0.8);
    border-radius: 8px;
  }

  .amazon-card-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 10px;
    background-color: var(--accent);
    color: #fff;
  }

  .amazon-card-text {
    flex: 1;
    min-width: 0;
    text-align: left;
  }

  .amazon-card-title {
    display: block;
    font-size: 0.95em;
    font-weight: 700;
    color: rgb(var(--black));
    margin-bottom: 0.2em;
  }

  .amazon-card-desc {
    display: block;
    font-size: 0.82em;
    color: rgb(var(--gray));
    line-height: 1.4;
  }

  .amazon-card-cta {
    flex-shrink: 0;
  }

  .amazon-card-btn {
    display: inline-block;
    padding: 0.5em 1em;
    border-radius: 6px;
    background-color: var(--accent);
    color: #fff;
    font-size: 0.82em;
    font-weight: 600;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .amazon-card-link:hover .amazon-card-btn {
    opacity: 0.85;
  }

  .affiliate-close {
    position: absolute;
    top: 0.5em;
    right: 0.7em;
    background: none;
    border: none;
    font-size: 1.3em;
    cursor: pointer;
    color: rgb(var(--gray));
    line-height: 1;
    padding: 0.2em;
    transition: color 0.2s ease;
  }

  .affiliate-close:hover {
    color: rgb(var(--gray-dark));
  }

  .affiliate-coupang-widget {
    margin-bottom: 0.5em;
    overflow: hidden;
    border-radius: 6px;
  }

  @media (max-width: 900px) {
    .affiliate-card {
      padding: 1em;
    }

    .amazon-card-inner {
      flex-direction: column;
      text-align: center;
      gap: 0.8em;
    }

    .amazon-card-text {
      text-align: center;
    }

    .amazon-card-icon {
      width: 44px;
      height: 44px;
    }

    .amazon-card-icon svg {
      width: 28px;
      height: 28px;
    }
  }
</style>
