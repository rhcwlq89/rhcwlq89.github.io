---
import { getCollection } from "astro:content";
import BaseHead from "../../../components/BaseHead.astro";
import Footer from "../../../components/Footer.astro";
import Header from "../../../components/Header.astro";
import { SITE_TITLE } from "../../../consts";
import { isPublished } from "../../../utils/posts";
import { collectTags } from "../../../utils/tags";

const posts = (await getCollection("blog")).filter(
  (post) => !post.id.startsWith("en/") && isPublished(post),
);
const tags = collectTags(posts);
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead
      title={`태그 | ${SITE_TITLE}`}
      description="모든 블로그 글을 태그별로 모아 봅니다."
      lang="ko"
      noindex
    />
    <style>
      main {
        width: 800px;
        max-width: calc(100% - 2em);
        margin: 2em auto;
      }
      h1 {
        margin-bottom: 0.5em;
      }
      .lead {
        color: rgb(var(--gray));
        margin-bottom: 2em;
      }
      ul.tag-cloud {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.6em;
      }
      ul.tag-cloud li a {
        display: inline-flex;
        align-items: baseline;
        gap: 0.4em;
        padding: 0.4em 0.9em;
        border-radius: 999px;
        background: rgba(var(--gray), 0.12);
        color: rgb(var(--gray-dark));
        text-decoration: none;
        font-size: 0.95em;
      }
      ul.tag-cloud li a:hover {
        background: rgb(var(--accent));
        color: white;
      }
      ul.tag-cloud li .count {
        font-size: 0.8em;
        opacity: 0.7;
      }
      .breadcrumb {
        font-size: 0.9em;
        margin-bottom: 1em;
        color: rgb(var(--gray));
      }
      .breadcrumb a {
        color: rgb(var(--gray-dark));
      }
    </style>
  </head>
  <body>
    <Header lang="ko" />
    <main>
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/">홈</a> &rsaquo; <a href="/blog/">블로그</a> &rsaquo; 태그
      </nav>
      <h1>태그</h1>
      <p class="lead">총 {tags.length}개의 태그, {posts.length}개의 글</p>
      <ul class="tag-cloud">
        {
          tags.map((t) => (
            <li>
              <a href={`/blog/tags/${t.slug}/`}>
                <span>{t.tag}</span>
                <span class="count">{t.posts.length}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer lang="ko" />
  </body>
</html>
