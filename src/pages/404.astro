---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead
      title={`404 - 페이지를 찾을 수 없습니다 | ${SITE_TITLE}`}
      description="요청하신 페이지를 찾을 수 없습니다."
      lang="ko"
    />
    <meta name="robots" content="noindex" />
    <style>
      main {
        width: 800px;
        max-width: calc(100% - 2em);
        margin: 4em auto;
        text-align: center;
      }
      h1 {
        font-size: 4rem;
        margin: 0 0 0.2em;
      }
      .lang-block {
        margin: 2em 0;
      }
      .lang-block p {
        margin: 0.4em 0;
      }
      .actions {
        margin-top: 1em;
        display: flex;
        gap: 1em;
        justify-content: center;
        flex-wrap: wrap;
      }
      .actions a {
        padding: 0.5em 1em;
        border-radius: 8px;
        background: rgb(var(--accent));
        color: white;
        text-decoration: none;
        font-size: 0.95em;
      }
      .actions a.secondary {
        background: transparent;
        color: rgb(var(--accent));
        border: 1px solid rgb(var(--accent));
      }
      hr.divider {
        width: 60%;
        margin: 2em auto;
        border: none;
        border-top: 1px solid rgb(var(--gray-light));
      }
    </style>
  </head>
  <body>
    <Header lang="ko" />
    <main>
      <h1>404</h1>
      <div class="lang-block">
        <p>요청하신 페이지를 찾을 수 없습니다.</p>
        <p>주소가 변경되었거나 삭제되었을 수 있어요.</p>
        <div class="actions">
          <a href="/">홈으로</a>
          <a href="/blog/" class="secondary">블로그 목록</a>
        </div>
      </div>
      <hr class="divider" />
      <div class="lang-block">
        <p>The page you requested could not be found.</p>
        <p>The URL may have changed or the page may have been removed.</p>
        <div class="actions">
          <a href="/en/">Home</a>
          <a href="/en/blog/" class="secondary">Blog</a>
        </div>
      </div>
    </main>
    <Footer lang="ko" />
  </body>
</html>
