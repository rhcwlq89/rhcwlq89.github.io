---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../../../components/BaseHead.astro";
import Footer from "../../../../components/Footer.astro";
import FormattedDate from "../../../../components/FormattedDate.astro";
import Header from "../../../../components/Header.astro";
import { SITE_TITLE } from "../../../../consts";
import { collectTags } from "../../../../utils/tags";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) =>
    post.id.startsWith("en/"),
  );
  return collectTags(posts).map((bucket) => ({
    params: { tag: bucket.slug },
    props: { tag: bucket.tag, posts: bucket.posts },
  }));
}

const { tag, posts } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`#${tag} | ${SITE_TITLE}`}
      description={`${posts.length} posts tagged with '${tag}'.`}
      lang="en"
    />
    <style>
      main {
        width: 800px;
        max-width: calc(100% - 2em);
        margin: 2em auto;
      }
      h1 {
        margin-bottom: 0.2em;
      }
      .lead {
        color: rgb(var(--gray));
        margin-bottom: 2em;
      }
      .breadcrumb {
        font-size: 0.9em;
        margin-bottom: 1em;
        color: rgb(var(--gray));
      }
      .breadcrumb a {
        color: rgb(var(--gray-dark));
      }
      ul.posts {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 1.5em;
      }
      ul.posts li a {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 1em;
        text-decoration: none;
        color: inherit;
        padding: 0.5em;
        border-radius: 12px;
        transition: background 0.2s;
      }
      ul.posts li a:hover {
        background: rgba(var(--gray), 0.08);
      }
      ul.posts img {
        width: 160px;
        height: 90px;
        object-fit: cover;
        border-radius: 8px;
      }
      ul.posts h3 {
        margin: 0 0 0.3em;
        color: rgb(var(--black));
      }
      ul.posts li a:hover h3 {
        color: rgb(var(--accent));
      }
      .post-date {
        color: rgb(var(--gray));
        font-size: 0.9em;
      }
      .post-desc {
        color: rgb(var(--gray-dark));
        font-size: 0.95em;
        margin-top: 0.4em;
      }
      @media (max-width: 600px) {
        ul.posts li a {
          grid-template-columns: 1fr;
        }
        ul.posts img {
          width: 100%;
          height: auto;
        }
      }
    </style>
  </head>
  <body>
    <Header lang="en" />
    <main>
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/en/">Home</a> &rsaquo; <a href="/en/blog/">Blog</a> &rsaquo;
        <a href="/en/blog/tags/">Tags</a> &rsaquo; #{tag}
      </nav>
      <h1>#{tag}</h1>
      <p class="lead">{posts.length} posts</p>
      <ul class="posts">
        {
          posts.map((post) => (
            <li>
              <a href={`/en/blog/${post.id.replace("en/", "")}/`}>
                {post.data.heroImage && (
                  <Image
                    width={320}
                    height={180}
                    src={post.data.heroImage}
                    alt={post.data.title}
                    loading="lazy"
                  />
                )}
                <div>
                  <h3>{post.data.title}</h3>
                  <p class="post-date">
                    <FormattedDate date={post.data.pubDate} lang="en" />
                  </p>
                  <p class="post-desc">{post.data.description}</p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer lang="en" />
  </body>
</html>
